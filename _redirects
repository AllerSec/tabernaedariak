# Netlify redirects — sitio multiidioma (eu por defecto)

# Detección de idioma del navegador en la raíz, con fallback a euskara
/  /es/  302  Language=es
/  /en/  302  Language=en
/  /fr/  302  Language=fr
/  /eu/  302

# Rutas antiguas mono-idioma → euskara (301, para no perder SEO/enlaces existentes)
/catalogo/*        /eu/catalogo/:splat  301
/empresa/*         /eu/empresa/:splat   301
/contacto/*        /eu/contacto/:splat  301
/aviso-legal/*     /eu/aviso-legal/:splat        301
/politica-privacidad/*  /eu/politica-privacidad/:splat  301
/politica-cookies/*     /eu/politica-cookies/:splat     301
